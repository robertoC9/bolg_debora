# ======================
#  BLOG BACKEND — ENV VARIABLES
#  Copia este archivo como .env y completa los valores
# ======================

# Puerto del servidor
PORT=3001

# ======================
#  PostgreSQL (Render)
# ======================
DATABASE_URL=postgresql://usuario:password@host:5432/debbie_blog

# ======================
#  Cloudinary
# ======================
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ======================
#  JWT (autenticación)
# ======================
JWT_SECRET=un_secreto_muy_largo_y_seguro_cambiar_en_produccion
JWT_EXPIRES_IN=7d

# ======================
#  CORS (origen del frontend)
# ======================
FRONTEND_URL=https://tu-frontend.onrender.com
